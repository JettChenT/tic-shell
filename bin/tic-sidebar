#!/usr/bin/env bash
set -euo pipefail

action="${1:-toggle}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
config_path="${TIC_SHELL_SIDEBAR_CONFIG:-$repo_root/shell/noctalia}"

export TIC_SHELL_ROOT="${TIC_SHELL_ROOT:-$repo_root}"
export NOCTALIA_CONFIG_DIR="${NOCTALIA_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/tic-shell/noctalia}"
export NOCTALIA_CACHE_DIR="${NOCTALIA_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/tic-shell/noctalia}"

find_quickshell() {
  if [[ -n "${TIC_QUICKSHELL_BIN:-}" ]]; then
    printf '%s\n' "$TIC_QUICKSHELL_BIN"
    return
  fi
  if [[ -z "${IN_NIX_SHELL:-}" && -z "${TIC_SIDEBAR_NIX_FALLBACK:-}" ]] && command -v nix >/dev/null 2>&1 && [[ -f "$repo_root/flake.nix" ]]; then
    exec env TIC_SIDEBAR_NIX_FALLBACK=1 nix develop "$repo_root" -c "$0" "$action"
  fi
  if command -v qs >/dev/null 2>&1; then
    command -v qs
    return
  fi
  if command -v quickshell >/dev/null 2>&1; then
    command -v quickshell
    return
  fi
  if [[ -z "${TIC_SIDEBAR_NIX_FALLBACK:-}" ]] && command -v nix >/dev/null 2>&1 && [[ -f "$repo_root/flake.nix" ]]; then
    exec env TIC_SIDEBAR_NIX_FALLBACK=1 nix develop "$repo_root" -c "$0" "$action"
  fi
  echo "tic-sidebar: could not find qs or quickshell in PATH" >&2
  exit 127
}

qscmd="$(find_quickshell)"

case "$action" in
  ipc)
    shift
    exec "$qscmd" ipc -p "$config_path" "$@"
    ;;
  start)
    exec "$qscmd" -p "$config_path"
    ;;
  stop)
    exec "$qscmd" kill -p "$config_path"
    ;;
  toggle)
    exec "$qscmd" ipc -p "$config_path" call sidebar toggle
    ;;
  show)
    exec "$qscmd" ipc -p "$config_path" call sidebar reveal
    ;;
  hide)
    exec "$qscmd" ipc -p "$config_path" call sidebar hide
    ;;
  toggle-agent)
    exec "$qscmd" ipc -p "$config_path" call sidebar toggleAgent
    ;;
  show-agent)
    exec "$qscmd" ipc -p "$config_path" call sidebar revealAgent
    ;;
  hide-agent)
    exec "$qscmd" ipc -p "$config_path" call sidebar hideAgent
    ;;
  *)
    echo "usage: tic-sidebar [start|stop|toggle|show|hide|toggle-agent|show-agent|hide-agent|ipc ...]" >&2
    exit 64
    ;;
esac
