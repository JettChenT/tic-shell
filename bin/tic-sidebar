#!/usr/bin/env bash
set -euo pipefail

action="${1:-toggle}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
app_bin="${TIC_SHELL_APP_BIN:-$repo_root/target/debug/tic-shell-app}"

export TIC_SHELL_ROOT="${TIC_SHELL_ROOT:-$repo_root}"

run_app() {
  if [[ -x "$app_bin" ]]; then
    exec "$app_bin" "$@"
  fi

  exec cargo run --manifest-path "$repo_root/Cargo.toml" --package tic-shell-app -- "$@"
}

case "$action" in
  start)
    run_app start
    ;;
  stop|toggle|show|hide|toggle-agent|show-agent|hide-agent)
    run_app "$action"
    ;;
  *)
    echo "usage: tic-sidebar [start|stop|toggle|show|hide|toggle-agent|show-agent|hide-agent]" >&2
    exit 64
    ;;
esac
